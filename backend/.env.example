PROJECT_NAME=Future Transformation API
API_V1_STR=/api/v1

MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=future_transformation

SECRET_KEY=replace_with_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisAdminPassword123
BACKEND_CORS_ORIGINS=http://localhost:5173

IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
IMAGEKIT_UPLOAD_ENDPOINT=https://upload.imagekit.io/api/v1/files/upload
IMAGEKIT_FOLDER=/future-transformation-docs

PINECONE_API_KEY=your_pinecone_api_key
PINECONE_CLOUD=aws
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=documents-index

OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

EMBEDDING_DIMENSION=1536
SEARCH_TOP_K_DEFAULT=5
SEARCH_TOP_K_MAX=20
SEARCH_MIN_RELEVANCE_SCORE=0.1